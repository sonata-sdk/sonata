{
  "name": "sonata",
  "version": "4.0.0",
  "description": "High-performance Lavalink-compatible audio server for Discord bots",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sonata": "bin/sonata.js"
  },
  "scripts": {
    "build": "tsc",
    "build:native": "node-gyp rebuild",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "opusscript": "^0.1.1",
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
