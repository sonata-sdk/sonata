{
  "name": "sonata",
  "version": "4.0.0",
  "description": "High-performance Lavalink-compatible audio server for Discord bots",
  "type": "module",
  "imports": {
    "#*": "./dist/*.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sonata": "bin/sonata.js"
  },
  "scripts": {
    "build": "tsc",
    "build:native": "node-gyp rebuild",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ecliptia/faad2-wasm": "^2.11.2-ecliptia.1",
    "@performanc/voice": "^2.2.5",
    "@projectdysnomia/dysnomia": "^0.2.4",
    "@snazzah/davey": "^0.1.11",
    "@sonata-sdk/decoder": "^0.3.1",
    "@sonata-sdk/voice": "^1.0.9",
    "@sonata-sdk/ws": "^0.2.1",
    "chalk": "^5.6.2",
    "opusscript": "^0.1.1",
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "socks-proxy-agent": "^10.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
