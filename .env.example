# Sonata Configuration Environment Variables
# These override values in sonata.json

# Server
SONATA_HOST=0.0.0.0
SONATA_PORT=2333
SONATA_PASSWORD=youshallnotpass

# Logging
SONATA_LOG_LEVEL=info

# Spotify (optional - enables Spotify source + mirroring)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
